# LSEG Data Library (primary price source) — optional. If unset, or if no
# session can be opened, DataManager falls back to yfinance automatically.
# Also picked up by the library's own lseg-data.config.json discovery
# (LD_LIB_CONFIG_PATH) if you prefer a session config file instead.
LSEG_APP_KEY=your_lseg_app_key_here

# Macro data (src/data/macro_data.py) — both optional, reduced variable
# coverage if omitted (see CLAUDE.md / docs/architecture.md for which
# variables have no fallback without these).
TE_API_KEY=your_trading_economics_key_here
FRED_API_KEY=your_fred_key_here

# Optional overrides — sensible defaults are used if unset.
# CACHE_DIR=.cache
# CACHE_TTL_HISTORICAL=86400
# CACHE_TTL_INTRADAY=3600
# LOG_LEVEL=INFO
# LOG_FILE=logs/portfolio_optimizer.log
