# LSEG Data Library — optional. Used both as the primary price source
# (DataManager falls back to yfinance automatically if unset or if no
# session can be opened) and as the fallback source for several macro
# variables in src/data/macro_data.py (US_10Y, CPO, NICKEL, BI_RATE,
# CHINA_PMI). Also picked up by the library's own lseg-data.config.json
# discovery (LD_LIB_CONFIG_PATH) if you prefer a session config file instead.
LSEG_APP_KEY=your_lseg_app_key_here

# Macro data (src/data/macro_data.py) — optional, reduced variable
# coverage if omitted (see CLAUDE.md / docs/architecture.md for which
# variables have no fallback without it).
TE_API_KEY=your_trading_economics_key_here

# Optional overrides — sensible defaults are used if unset.
# CACHE_DIR=.cache
# CACHE_TTL_HISTORICAL=86400
# CACHE_TTL_INTRADAY=3600
# LOG_LEVEL=INFO
# LOG_FILE=logs/portfolio_optimizer.log
