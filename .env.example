# LSEG Data Library — optional. Used as the primary price source
# (DataManager falls back to yfinance automatically if unset or if no
# session can be opened) and as the primary source for macro contagion
# variables in src/data/macro_data.py (yfinance fallback there too,
# where a real equivalent ticker exists — 4 of 9 variables have none,
# see CLAUDE.md's Known placeholders entry). Also picked up by the
# library's own lseg-data.config.json discovery (LD_LIB_CONFIG_PATH)
# if you prefer a session config file instead.
LSEG_APP_KEY=your_lseg_app_key_here

# Optional overrides — sensible defaults are used if unset.
# CACHE_DIR=.cache
# CACHE_TTL_HISTORICAL=86400
# CACHE_TTL_INTRADAY=3600
# LOG_LEVEL=INFO
# LOG_FILE=logs/portfolio_optimizer.log
